# InventoryAI Environment Configuration
# Copy to .env and edit values for your deployment.

# Device Identity
APP_ID=batch_count
DEVICE_ID=INV-RPi-001

# Firebase (shared project: surgicalai01)
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json
FIREBASE_PROJECT_ID=surgicalai01
FIREBASE_STORAGE_BUCKET=surgicalai01.firebasestorage.app
FIREBASE_SIMULATE=false

# Inference (Mac simulation)
MOCK_LABELS=bolt_m6,washer_m6,nut_m6
MOCK_MIN_COUNT=1
MOCK_MAX_COUNT=5

# Mode: batch_count
COUNTING_WINDOW_SEC=5
COUNT_TOLERANCE=0

# Mode: bundle_check
BUNDLE_TIMEOUT_SEC=10

# Mode: area_monitor
LOW_STOCK_THRESHOLD=5
HIGH_STOCK_THRESHOLD=50
AREA_SNAPSHOT_INTERVAL_SEC=30
LOCATION_NAME=Rack A
